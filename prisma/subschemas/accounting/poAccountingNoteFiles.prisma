model PoAccountingNoteFile {
    id                 String           @id @default(uuid())
    poAccountingNoteId String           @map("po_accounting_note_id")
    fileId             String           @map("file_id")
    createdAt          DateTime         @default(now()) @map("created_at")
    updatedAt          DateTime         @updatedAt @map("updated_at")
    poAccountingNote   PoAccountingNote @relation(fields: [poAccountingNoteId], references: [id])
    file               File             @relation(fields: [fileId], references: [id])

    @@map("po_accounting_note_files")
}
