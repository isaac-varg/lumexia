model PricingExaminationNoteFile {
    id                       String                 @id @default(uuid())
    pricingExaminationNoteId String                 @map("pricing_examination_note_id")
    fileId                   String                 @map("file_id")
    createdAt                DateTime               @default(now()) @map("created_at")
    updatedAt                DateTime               @updatedAt @map("updated_at")
    pricingExaminationNote   PricingExaminationNote @relation(fields: [pricingExaminationNoteId], references: [id])
    file                     File                   @relation(fields: [fileId], references: [id])

    @@map("pricing_examination_note_files")
}
