model File {
    id                     String               @id @default(uuid())
    name                   String
    objectName             String               @unique @map("object_name")
    bucketName             String               @map("bucket_name")
    thumbnailObjectName    String?              @unique @map("thumbnail_object_name")
    thumbnailBucketName    String?              @map("thumbnail_bucket_name")
    etag                   String
    versionId              String?              @map("version_id")
    size                   Int
    mimeType               String               @map("mime_type")
    public                 Boolean              @default(false)
    uploadedById           String               @map("uploaded_by_id")
    createdAt              DateTime             @default(now()) @map("created_at")
    updatedAt              DateTime             @updatedAt @map("updated_at")
    uploadedBy             User                 @relation(fields: [uploadedById], references: [id])
    poAccountingFiles      PoAccountingFile[]
    generalRequestFiles    GeneralRequestFile[]
    itemFiles              ItemFile[]
    bprStagingFiles        BprStagingFile[]
    qcRecordFiles                  QcRecordFile[]
    requestNoteFiles               RequestNoteFile[]
    generalRequestNoteFiles        GeneralRequestNoteFile[]
    purchaseOrderNoteFiles         PurchaseOrderNoteFile[]
    poPublicNoteFiles              PoPublicNoteFile[]
    poSupplierNoteFiles            PoSupplierNoteFile[]
    poAccountingNoteFiles          PoAccountingNoteFile[]
    pricingExaminationNoteFiles    PricingExaminationNoteFile[]
    auditRequestNoteFiles          AuditRequestNoteFile[]
    discrepancyAuditItemNoteFiles  DiscrepancyAuditItemNoteFile[]
    lotNoteFiles                   LotNoteFile[]
    itemNoteFiles                  ItemNoteFile[]
    bprNoteFiles                   BprNoteFile[]
    qcRecordNoteFiles              QcRecordNoteFile[]
    mbprNoteFiles                  MbprNoteFile[]
    fileTags                       FileTag[]

    @@map("files")
}
